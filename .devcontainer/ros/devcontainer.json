{
  "name": "ROS2 Plugin Development Environment",
  "build": { "dockerfile": "../../plugins/ros/Dockerfile" },
  "remoteUser": "ubuntu",
  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd"
      ]
    }
  },
  "runArgs": [
    "--network=host",
    "--cap-add=SYS_PTRACE",
    "--security-opt", "seccomp=unconfined"
  ]
}